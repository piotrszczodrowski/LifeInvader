{% extends "base.html.twig" %}

{% block title %}Błąd {{ code }} - LifeInvader{% endblock %}

{% block content %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-6 text-center">
            <div class="p-5 bg-white rounded-4 shadow-sm border">
                <h1 class="display-1 fw-black text-danger mb-2" style="font-weight: 900; opacity: 0.8;">
                    {{ code }}
                </h1>

                <h3 class="text-dark fw-bold mb-3">Ups! Coś poszło nie tak</h3>

                <p class="text-muted fs-5 mb-4">
                    {{ message }}
                </p>

                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <a href="/" class="btn btn-primary btn-lg px-4 gap-3 rounded-pill">
                        Wróć do strony głównej
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}