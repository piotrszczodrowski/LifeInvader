{% extends "base.html.twig" %}

{% block title %}Błąd {{ code }} - LifeInvader{% endblock %}

{% block content %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <div class="p-5 bg-light border rounded-4 shadow-sm">
                    <h1 class="display-1 fw-bold text-danger">{{ code }}</h1>
                    <p class="lead fw-bold">{{ message }}</p>

                    {% if details %}
                        <div class="card text-start mt-4">
                            <div class="card-header fw-bold">Szczegóły techniczne</div>
                            <div class="card-body bg-dark text-light font-monospace small">
                                {{ details }}
                            </div>
                        </div>
                    {% endif %}

                    <a href="/" class="btn btn-primary mt-4">Wróć na stronę główną</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}