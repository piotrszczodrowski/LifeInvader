{% extends 'base.html.twig' %}
{% block title %}Wiadomości Prywatne - LifeInvader{% endblock %}

{% block content %}
    <div class="container mt-4 mb-4">
        <div class="row g-3" style="height: 84vh; min-height: 650px;">

            {# LEWA KOLUMNA: LISTA KONTAKTÓW #}
            <div class="col-md-4 h-100">
                <div class="card shadow-sm border-0 rounded-4 h-100 d-flex flex-column">
                    <div class="card-header bg-dark text-white border-0 rounded-top-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-chat-left-text-fill me-2"></i>Konwersacje</h5>
                    </div>
                    <div class="bg-body-tertiary border-bottom p-2">
                        <form action="/messages" method="GET" class="d-flex gap-2 m-0">
                            <select name="user_id" class="form-select form-select-sm rounded-pill" required>
                                <option value="" disabled selected>Nowa wiadomość do...</option>
                                {% for u in all_users %}
                                    <option value="{{ u.id }}">@{{ u.username }}</option>
                                {% endfor %}
                            </select>
                            <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3" title="Rozpocznij">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </form>
                    </div>
                    <div class="list-group list-group-flush rounded-bottom-4 overflow-y-auto flex-grow-1">
                        {% for contact in contacts %}
                            <a href="?user_id={{ contact.id }}" class="list-group-item list-group-item-action d-flex align-items-center justify-content-between py-3 {% if active_contact and active_contact.id == contact.id %}active bg-danger border-danger{% endif %}">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="{{ contact.avatar_path|default('/uploads/avatars/default.png') }}" class="rounded-circle border border-2 border-white" style="width: 40px; height: 40px; object-fit: cover;">
                                    <span id="sidebar-name-{{ contact.id }}" class="{% if contact.unread_count > 0 and (not active_contact or active_contact.id != contact.id) %}fw-black text-danger{% else %}fw-semibold{% endif %}">
                                        @{{ contact.username }}
                                    </span>
                                </div>
                                <span id="sidebar-badge-{{ contact.id }}" class="badge bg-danger rounded-pill shadow-sm" {% if not (contact.unread_count > 0 and (not active_contact or active_contact.id != contact.id)) %}style="display: none;"{% endif %}>
                                    {{ contact.unread_count }}
                                </span>
                            </a>
                        {% else %}
                            <div class="text-center p-4 text-body-secondary small">Skrzynka jest pusta.</div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {# PRAWA KOLUMNA: OKNO CZATU #}
            <div class="col-md-8 h-100">
                {% if active_contact %}
                    <div class="card shadow-sm border-0 rounded-4 h-100 d-flex flex-column">
                        <div class="card-header bg-body-tertiary border-bottom py-3 d-flex align-items-center gap-3 rounded-top-4">
                            <img src="{{ active_contact.avatar_path|default('/uploads/avatars/default.png') }}" class="rounded-circle border" style="width: 35px; height: 35px; object-fit: cover;">
                            <h6 class="mb-0 fw-bold">Rozmowa z @{{ active_contact.username }}</h6>
                        </div>
                        <div class="card-body overflow-y-auto bg-light-subtle p-4 d-flex flex-column gap-2 flex-grow-1" id="chatWindow">
                            {% for msg in conversation %}
                                {% set is_me = (msg.sender_id == session.user_id) %}
                                <div class="d-flex {% if is_me %}justify-content-end is-me{% else %}justify-content-start{% endif %} msg-row" data-id="{{ msg.id }}">
                                    <div class="card border-0 rounded-4 px-3 py-2 max-w-75 shadow-sm {% if is_me %}bg-danger text-white rounded-bottom-end-0{% else %}bg-body-secondary text-body rounded-bottom-start-0{% endif %}">
                                        <p class="mb-1 text-break">{{ msg.content|escape }}</p>
                                        <small class="d-block text-end {% if is_me %}text-white-50{% else %}text-body-secondary{% endif %}" style="font-size: 0.7rem;">
                                            {{ msg.created_at|date('Y/m/d H:i') }}
                                            {% if is_me %}
                                                <span class="read-status ms-1">
                                                    {% if msg.is_read %}<i class="bi bi-check-all text-info" title="Odczytano"></i>{% else %}<i class="bi bi-check text-white-50" title="Dostarczono"></i>{% endif %}
                                                </span>
                                            {% endif %}
                                        </small>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <div class="card-footer bg-body-tertiary border-top p-3 rounded-bottom-4 mt-auto">
                            <form id="chatForm" autocomplete="off" class="m-0">
                                <input type="hidden" id="receiverId" value="{{ active_contact.id }}">
                                <input type="hidden" id="currentUserId" value="{{ session.user_id }}">
                                <div class="input-group">
                                    <input type="text" id="msgContent" class="form-control rounded-pill-start px-3" placeholder="Napisz wiadomość..." required>
                                    <button type="submit" class="btn btn-danger rounded-pill-end px-4 fw-bold"><i class="bi bi-send-fill"></i></button>
                                </div>
                            </form>
                        </div>
                    </div>
                {% else %}
                    <div class="card shadow-sm border-0 rounded-4 h-100 d-flex align-items-center justify-content-center text-center p-5 text-body-secondary bg-body-tertiary">
                        <div>
                            <i class="bi bi-chat-square-dots-fill text-danger mb-3" style="font-size: 4rem;"></i>
                            <h5 class="fw-bold text-body">Twoja skrzynka odbiorcza</h5>
                            <p class="small">Wybierz osobę z listy lub użyj pola powyżej, aby rozpocząć nową konwersację.</p>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <style>
        .max-w-75 { max-width: 75%; }
        .rounded-bottom-end-0 { border-bottom-right-radius: 0 !important; }
        .rounded-bottom-start-0 { border-bottom-left-radius: 0 !important; }
        .fw-black { font-weight: 900 !important; }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const chatWindow = document.getElementById('chatWindow');
            if (!chatWindow) return;

            const chatForm = document.getElementById('chatForm');
            const receiverIdInput = document.getElementById('receiverId');
            const currentUserIdInput = document.getElementById('currentUserId');
            const msgContentInput = document.getElementById('msgContent');

            function scrollToBottom() {
                chatWindow.scrollTop = chatWindow.scrollHeight;
            }
            scrollToBottom();

            function getLastMessageId() {
                const rows = chatWindow.querySelectorAll('.msg-row');
                return rows.length > 0 ? parseInt(rows[rows.length - 1].getAttribute('data-id')) : 0;
            }

            function formatDateTime(dateString) {
                const date = new Date(dateString);
                const pad = (num) => num.toString().padStart(2, '0');
                const yyyy = date.getFullYear();
                const mm = pad(date.getMonth() + 1);
                const dd = pad(date.getDate());
                const hh = pad(date.getHours());
                const min = pad(date.getMinutes());
                return `${yyyy}/${mm}/${dd} ${hh}:${min}`;
            }

            function appendMessage(msg, currentUserId) {
                const isMe = (parseInt(msg.sender_id) === parseInt(currentUserId));
                const row = document.createElement('div');
                row.className = `d-flex ${isMe ? 'justify-content-end is-me' : 'justify-content-start'} msg-row`;
                row.setAttribute('data-id', msg.id);

                const timeStr = formatDateTime(msg.created_at);
                const statusHtml = isMe ? `<span class="read-status ms-1"><i class="bi bi-check text-white-50" title="Dostarczono"></i></span>` : '';

                row.innerHTML = `
                    <div class="card border-0 rounded-4 px-3 py-2 max-w-75 shadow-sm ${isMe ? 'bg-danger text-white rounded-bottom-end-0' : 'bg-body-secondary text-body rounded-bottom-start-0'}">
                        <p class="mb-1 text-break">${msg.content.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</p>
                        <small class="d-block text-end ${isMe ? 'text-white-50' : 'text-body-secondary'}" style="font-size: 0.7rem;">
                            ${timeStr} ${statusHtml}
                        </small>
                    </div>
                `;
                chatWindow.appendChild(row);
                scrollToBottom();
            }

            setInterval(() => {
                const activeUser = receiverIdInput.value;
                const lastId = getLastMessageId();
                fetch(`/api/messages/fetch?user_id=${activeUser}&last_id=${lastId}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.status !== 'success') return;
                        if (data.max_read_id > 0) {
                            document.querySelectorAll('.msg-row.is-me').forEach(row => {
                                if (parseInt(row.getAttribute('data-id')) <= data.max_read_id) {
                                    const statusSpan = row.querySelector('.read-status');
                                    if (statusSpan && !statusSpan.innerHTML.includes('bi-check-all')) {
                                        statusSpan.innerHTML = '<i class="bi bi-check-all text-info" title="Odczytano"></i>';
                                    }
                                }
                            });
                        }
                        if (data.messages.length > 0) {
                            data.messages.forEach(msg => appendMessage(msg, data.current_user_id));
                        }
                    }).catch(err => console.error("Błąd pobierania wiadomości:", err));
            }, 1000);

            chatForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const content = msgContentInput.value.trim();
                if (!content) return;

                const formData = new FormData();
                formData.append('receiver_id', receiverIdInput.value);
                formData.append('content', content);

                fetch('/messages/send', { method: 'POST', body: formData })
                    .then(res => res.json())
                    .then(data => {
                        if (data.status === 'success' && data.message) {
                            msgContentInput.value = '';
                            appendMessage(data.message, currentUserIdInput.value);
                        } else {
                            alert("Błąd podczas wysyłania: " + (data.message || 'Nieznany błąd'));
                        }
                    }).catch(err => console.error("Błąd wysyłania wiadomości:", err));
            });
        });
    </script>
{% endblock %}