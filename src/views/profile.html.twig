{% extends "base.html.twig" %}
{% block title %}Profil @{{ profile_user.username }} - LifeInvader{% endblock %}

{% block content %}
    <div class="container mt-4">
        <div class="row">

            {# Lewa kolumna - Informacje o użytkowniku #}
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0 rounded-4 text-center p-4">
                    <img src="{{ profile_user.avatar_path|default('/uploads/avatars/default.png') }}" alt="Awatar"
                         class="rounded-circle img-thumbnail mx-auto mb-3"
                         style="width: 150px; height: 150px; object-fit: cover;">

                    <h3 class="fw-bold">@{{ profile_user.username }}</h3>
                    <p class="text-muted small">Dołączył(a): {{ profile_user.created_at|date('d.m.Y') }}</p>

                    <p class="mb-4">
                        {{ profile_user.bio ?: 'Ten użytkownik nie dodał jeszcze opisu.' }}
                    </p>

                    {# NOWE: Przycisk "Napisz wiadomość" ląduje elegancko pod opisem #}
                    {% if session.user_id and session.user_id != profile_user.id %}
                        <div class="mt-4">
                            <a href="/messages?user_id={{ profile_user.id }}" class="btn btn-danger rounded-pill fw-bold px-4 shadow-sm">
                                <i class="bi bi-chat-dots-fill me-2"></i> Napisz wiadomość
                            </a>
                        </div>
                    {% endif %}

                    {% if session.user_id == profile_user.id %}
                        <a href="/profile/edit" class="btn btn-outline-primary w-100 rounded-pill">Edytuj profil</a>
                    {% endif %}
                </div>
            </div>

            {# Prawa kolumna - Posty użytkownika (korzysta z partiala DRY) #}
            <div class="col-md-8">
                <h4 class="mb-4">Aktywność użytkownika</h4>

                {% for post in posts %}
                    {% include 'partials/post_card.html.twig' %}
                {% else %}
                    <div class="alert alert-info text-center rounded-4">
                        Ten użytkownik nie napisał jeszcze żadnego posta.
                    </div>
                {% endfor %}
            </div>

        </div>
    </div>
{% endblock %}