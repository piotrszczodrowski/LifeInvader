{% extends 'base.html.twig' %}
{% block title %}Edytuj wpis - LifeInvader{% endblock %}

{% block content %}
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-primary text-white border-0 rounded-top-4 py-3">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Edytuj swój wpis</h5>
                    </div>
                    <div class="card-body">
                        <form action="/post/update/{{ post.id }}" method="POST" id="editPostForm">

                            {# Kontener Quilla wypełniony z góry starym tekstem z bazy #}
                            <div id="quill-editor" style="height: 200px; border-bottom-left-radius: 0; border-bottom-right-radius: 0;">
                                {{ post.content|raw }}
                            </div>

                            <input type="hidden" name="content" id="hidden-content">

                            <div class="d-flex justify-content-between align-items-center mt-3 border p-2 rounded-bottom bg-body-tertiary" style="border-top: none !important;">
                                <a href="/" class="btn btn-outline-secondary rounded-pill fw-bold px-4">Anuluj</a>
                                <button type="submit" class="btn btn-primary fw-bold rounded-pill px-4">Zapisz zmiany</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script>
        var quill = new Quill('#quill-editor', {
            theme: 'snow',
            placeholder: 'Zmień treść posta...',
            modules: {
                toolbar: [
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link']
                ]
            }
        });

        // Pancerne przechwycenie wysyłania formularza
        var form = document.getElementById('editPostForm');
        var hiddenInput = document.getElementById('hidden-content');

        form.addEventListener('submit', function(e) {
            // Wyciągamy HTML z edytora
            var html = quill.root.innerHTML;

            // Jeśli edytor jest pusty, Quill wstawia <p><br></p>. Czyścimy to.
            if (html === '<p><br></p>') {
                html = '';
            }

            // Zapisujemy do ukrytego inputa
            hiddenInput.value = html;

            // Mały debug (możesz usunąć po teście)
            // console.log("Wysyłam do bazy:", hiddenInput.value);
        });
    </script>
{% endblock %}