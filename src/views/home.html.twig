{% extends 'base.html.twig' %}

{% block content %}
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <div class="container mt-4">
        {# Formularz tworzenia posta z obsługą plików #}
        <div class="card mb-4 shadow-sm border-0 rounded-4">
            <div class="card-body">
                <form action="/post/create" method="POST" enctype="multipart/form-data" id="postForm">

                    {# Kontener na edytor Quill #}
                    <div id="quill-editor" style="height: 120px; border-bottom-left-radius: 0; border-bottom-right-radius: 0;"></div>

                    {# Ukryte pole, do którego JS przerzuci HTML z Quilla przed wysłaniem #}
                    <input type="hidden" name="content" id="hidden-content">

                    <div class="d-flex justify-content-between align-items-center mt-2 border p-2 rounded-bottom bg-body-tertiary" style="border-top: none !important;">
                        <div>
                            <label for="post-images" class="btn btn-sm btn-outline-secondary mb-0">
                                <i class="bi bi-camera"></i> Dodaj zdjęcia
                            </label>
                            <input type="file" id="post-images" name="images[]" multiple accept="image/*" class="d-none">
                            <span id="file-count" class="small ms-2 text-muted"></span>
                        </div>
                        <button type="submit" class="btn btn-primary fw-bold rounded-pill px-4">Opublikuj</button>
                    </div>
                </form>
            </div>
        </div>

        {# Pasek sortowania #}
        <div class="d-flex gap-2 mb-3">
            <a href="?sort=last_activity_at" class="btn btn-sm {% if current_sort == 'last_activity_at' or not current_sort %}btn-dark{% else %}btn-outline-dark{% endif %}">
                Najnowsza aktywność
            </a>
            <a href="?sort=created_at" class="btn btn-sm {% if current_sort == 'created_at' %}btn-dark{% else %}btn-outline-dark{% endif %}">
                Najnowsze posty
            </a>
        </div>

        {# Lista postów (korzysta z partiala DRY) #}
        {% for post in posts %}
            {% include 'partials/post_card.html.twig' %}
        {% else %}
            <div class="alert alert-info text-center rounded-4">
                Brak postów. Bądź pierwszy i napisz coś!
            </div>
        {% endfor %}
    </div>

    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script>
        var quill = new Quill('#quill-editor', {
            theme: 'snow',
            placeholder: 'Co Ci chodzi po głowie? Użyj @ żeby kogoś oznaczyć!',
            modules: {
                toolbar: [
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link']
                ]
            }
        });

        document.getElementById('postForm').onsubmit = function() {
            document.getElementById('hidden-content').value = quill.root.innerHTML;
        };

        document.getElementById('post-images').addEventListener('change', function() {
            var count = this.files.length;
            document.getElementById('file-count').textContent = count > 0 ? 'Wybrano plików: ' + count : '';
        });
    </script>
{% endblock %}