{% extends "base.html.twig" %}

{% block title %}{{ title|default('Zmień hasło') }} - LifeInvader{% endblock %}

{% block content %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-4 p-4">
                <h2 class="fw-bold mb-3 text-center">{{ title|default('Zmień hasło') }}</h2>

                <div class="alert alert-info border-0 shadow-sm mb-4">
                    <i class="bi bi-info-circle-fill me-2"></i> {{ message }}
                </div>

                {% if error %}
                    <div class="alert alert-danger">{{ error }}</div>
                {% endif %}

                <form action="{{ form_action|default('/force-password-change') }}" method="POST">
                    <div class="mb-3">
                        <label for="change-password" class="form-label">Nowe hasło</label>
                        <div class="input-group">
                            <input type="password" id="change-password" name="password" class="form-control toggle-target" required>
                            <button class="btn btn-outline-secondary toggle-password" type="button" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="change-password-confirm" class="form-label">Powtórz nowe hasło</label>
                        <div class="input-group">
                            <input type="password" id="change-password-confirm" name="password_confirm" class="form-control toggle-target" required>
                            <button class="btn btn-outline-secondary toggle-password" type="button" tabindex="-1">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-danger w-100 fw-bold rounded-pill">Zapisz nowe hasło</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.toggle-password').forEach(button => {
            button.addEventListener('click', function() {
                const passwordInputs = document.querySelectorAll('.toggle-target');
                const icons = document.querySelectorAll('.toggle-password i');
                const isPassword = passwordInputs[0].type === 'password';

                passwordInputs.forEach(input => {
                    input.type = isPassword ? 'text' : 'password';
                });

                icons.forEach(icon => {
                    if (isPassword) {
                        icon.classList.replace('bi-eye', 'bi-eye-slash');
                    } else {
                        icon.classList.replace('bi-eye-slash', 'bi-eye');
                    }
                });
            });
        });
    </script>
{% endblock %}