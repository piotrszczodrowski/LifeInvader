{% extends "base.html.twig" %}
{% block title %}Instalacja - LifeInvader{% endblock %}
{% block content %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-6 text-center p-5 bg-white rounded-4 shadow border border-primary">
            <h1 class="fw-bold text-primary mb-3">Witaj w instalatorze</h1>
            <p class="text-muted fs-5 mb-4">
                Wygląda na to, że system nie został jeszcze zainicjalizowany. Kliknij poniższy przycisk, aby wdrożyć strukturę bazy danych i utworzyć konto Administratora.
            </p>
            <form action="/install/run" method="POST">
                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold">
                    Rozpocznij instalację
                </button>
            </form>
        </div>
    </div>
{% endblock %}